{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Lumi OS",
  "version": "2.0.4",
  "identifier": "com.lumiai.os",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:server && npm run prepare:desktop",
    "beforeBundleCommand": "node scripts/copy-webview2-dll.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Lumi OS",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "resizable": true,
        "center": true,
        "alwaysOnBottom": false,
        "skipTaskbar": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": [
      "../desktop-resources/dist-server/**/*",
      "../desktop-resources/gpt-sovits-src/**/*",
      "../desktop-resources/data/voice_training/**/*",
      "../desktop-resources/WebView2Loader.dll"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./includes/include-dll.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY",
      "endpoints": [
        "https://releases.lumiai.asia/lumi-os/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
